# ==============================
# CaseSim staging (ejemplo)
# Copiar a .env.staging y completar valores reales
# ==============================

# Entorno
APP_ENV=staging

# CORS (coma separada)
APP_CORS_ALLOWED_ORIGINS=http://localhost:4200

# JWT (>= 32 chars)
JWT_SECRET=REEMPLAZAR_CON_SECRETO_LARGO_Y_ALEATORIO_32_CHARS_MIN
JWT_EXPIRATION_MS=900000

# DB (NO usar credenciales dev)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/casesim_staging_db
SPRING_DATASOURCE_USERNAME=casesim_staging_user
SPRING_DATASOURCE_PASSWORD=REEMPLAZAR_PASSWORD_STAGING_SEGURA

# Cifrado de API key LLM (>= 32 chars)
CASESIM_LLM_CIPHER_KEY=REEMPLAZAR_CON_LLAVE_LARGA_Y_ALEATORIA_32_CHARS_MIN

# LLM
LLM_ENABLED=false
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1/chat/completions
LLM_TIMEOUT_MS=30000
LLM_MAX_RETRIES=1
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=350
LLM_HISTORY_TURNS=6
