# ===================================================================
# CaseSim - Variables de entorno para servidor universitario
# ===================================================================
# INSTRUCCIONES:
#   1. Copiar este archivo como .env:  cp .env.example .env
#   2. Completar TODAS las variables marcadas con "changeme"
#   3. Proteger .env:  chmod 600 .env
#   4. NUNCA versionar .env, solo .env.example
# ===================================================================

# ------------------------------------------------------------------
# Base de datos PostgreSQL
# ------------------------------------------------------------------
POSTGRES_DB=casesim_db
POSTGRES_USER=casesim_app_user
POSTGRES_PASSWORD=changeme_password_postgres_largo

# ------------------------------------------------------------------
# Conexión a base de datos desde backend (usando Docker network)
# ------------------------------------------------------------------
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/casesim_db
SPRING_DATASOURCE_USERNAME=casesim_app_user
SPRING_DATASOURCE_PASSWORD=changeme_password_postgres_largo

# ------------------------------------------------------------------
# Entorno
# ------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=prod
APP_ENV=prod

# ------------------------------------------------------------------
# Seguridad JWT
# ------------------------------------------------------------------
# Generar con: openssl rand -base64 64
JWT_SECRET=changeme_jwt_secret_al_menos_256_bits_en_base64

# Duración del token JWT en milisegundos (15 min por defecto)
JWT_EXPIRATION_MS=900000

# ------------------------------------------------------------------
# Clave de cifrado para API keys LLM (AES-GCM)
# ------------------------------------------------------------------
# Generar con: openssl rand -base64 32
CASESIM_LLM_CIPHER_KEY=changeme_llm_cipher_key_minimo_32_chars

# ------------------------------------------------------------------
# CORS y frontend
# ------------------------------------------------------------------
# Orígenes permitidos para CORS (separados por coma si varios)
APP_CORS_ALLOWED_ORIGINS=http://IP_DEL_SERVIDOR

# URL base pública del frontend (para enlaces en emails, etc.)
APP_FRONTEND_BASE_URL=http://IP_DEL_SERVIDOR

# ------------------------------------------------------------------
# Reset de contraseñas
# ------------------------------------------------------------------
# MANUAL = solo admin puede resetear; DISABLED = sin reset
CASESIM_PASSWORD_RESET_MODE=MANUAL

# Token operativo para acciones administrativas sensibles
CASESIM_OPERATIONS_TOKEN=changeme_operations_token

# Token bootstrap (primer inicio)
BOOTSTRAP_TOKEN=changeme_bootstrap_token

# ------------------------------------------------------------------
# LLM (opcional - dejar deshabilitado si no se usa IA)
# ------------------------------------------------------------------
LLM_ENABLED=false
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1/chat/completions
LLM_TIMEOUT_MS=30000
LLM_MAX_RETRIES=1
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=350
LLM_HISTORY_TURNS=6
